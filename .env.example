# Zima Screens — Environment Variables
# Copy this file to .env and fill in your values.

# ── YouTube (Channel Pulse) ──────────────────────────
# Your channel ID (find it at youtube.com/account_advanced)
YOUTUBE_CHANNEL=UCxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: YouTube Data API v3 key (for subscriber count)
# Without this, everything else still works via RSS
YOUTUBE_API_KEY=

# ── Discord (Discord Monitor) ────────────────────────
# Bot token (create at discord.com/developers/applications)
DISCORD_TOKEN=
# Server (guild) ID
GUILD_ID=
# Channel name to monitor
DISCORD_CHANNEL=general

# ── Remote Device (Zima Monitor) ─────────────────────
# IP of the second device to monitor (leave empty for local-only mode)
REMOTE_IP=
# ZimaOS / CasaOS API credentials (port 8080)
REMOTE_API_PORT=8080
REMOTE_USER=
REMOTE_PASS=
# SSH fallback user (requires key-based auth)
REMOTE_SSH_USER=

# ── Screen (optional) ────────────────────────────────
# Override serial port auto-detection
# SERIAL_PORT=/dev/ttyACM0
