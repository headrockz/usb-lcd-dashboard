# Homelab Monitor — Environment Variables
# Copy this file to .env and fill in your values.

# ── Remote Device ─────────────────────────────────────
# IP of the second device to monitor (leave empty for local-only mode)
REMOTE_IP=
# SSH user (requires key-based auth)
REMOTE_SSH_USER=

# ── Screen (optional) ────────────────────────────────
# Override serial port auto-detection
# SERIAL_PORT=/dev/ttyACM0
# Screen orientation: portrait (em pé) or landscape (deitado)
MONITOR_ORIENTATION=portrait

# ── UI Text Customization ─────────────────────────────
# Text displayed in the monitor header and panel titles
MONITOR_TEXT=HOMELAB MONITOR
SERVER_1_TITLE=SERVER 1
SERVER_2_TITLE=SERVER 2

# ── Color Thresholds ─────────────────────────────────
# CPU / MEM / DISK usage thresholds (%)
USAGE_RED=80
USAGE_ORANGE=60
# Temperature thresholds (°C)
TEMP_RED=75
TEMP_ORANGE=60
# CPU bar panel thresholds (% for load, °C for temp)
CPU_BAR_RED=70
CPU_BAR_ORANGE=55
